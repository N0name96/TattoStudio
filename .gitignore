# ============================================================
# ROOT .gitignore — aplica a todo el monorepo TattoStudio
# ============================================================

# ----- OS -----
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
desktop.ini

# ----- IDEs y editores -----
.vs/
.vscode/settings.json
.vscode/launch.json
.idea/
*.suo
*.user
*.userprefs
*.swp
*.swo
*~

# ----- Claude Code (configuración local de permisos por máquina) -----
.claude/settings.local.json

# ----- Variables de entorno y secretos -----
.env
.env.*
!.env.example
*.pem
*.key
*.pfx
*.p12
*.cer

# ----- Logs -----
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
